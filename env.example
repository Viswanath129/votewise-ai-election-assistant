# VoteWise AI Environment Variables Example
# Copy this file to .env.local and fill in your values

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="VoteWise AI"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Analytics (Optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GTM_ID=

# Monitoring (Optional)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_MONITORING=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Security Configuration
NEXT_PUBLIC_SECURITY_MODE=production
NEXT_PUBLIC_RATE_LIMIT_ENABLED=true
NEXT_PUBLIC_RATE_LIMIT_REQUESTS=20
NEXT_PUBLIC_RATE_LIMIT_WINDOW=60000

# Performance Configuration
NEXT_PUBLIC_ENABLE_LAZY_LOADING=true
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=false

# Development Configuration
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info

# Deployment Configuration
NEXT_PUBLIC_DEPLOYMENT_ENV=development
NEXT_PUBLIC_REGION=asia-south1

# Content Delivery Network (Optional)
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_ASSET_PREFIX=

# API Configuration (Not used in offline mode)
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_API_KEY=

# Social Media Integration (Optional)
NEXT_PUBLIC_TWITTER_HANDLE=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_HANDLE=

# Contact Information
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_HELPLINE_NUMBER=1950

# Legal Information
NEXT_PUBLIC_PRIVACY_POLICY_URL=
NEXT_PUBLIC_TERMS_OF_SERVICE_URL=

# Localization
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,hi

# Cache Configuration
NEXT_PUBLIC_CACHE_DURATION=3600
NEXT_PUBLIC_ENABLE_OFFLINE_CACHE=true

# Theme Configuration
NEXT_PUBLIC_DEFAULT_THEME=system
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Accessibility Configuration
NEXT_PUBLIC_ENABLE_ACCESSIBILITY=true
NEXT_PUBLIC_ENABLE_SCREEN_READER=true
NEXT_PUBLIC_ENABLE_KEYBOARD_NAVIGATION=true

# Testing Configuration
NEXT_PUBLIC_TEST_MODE=false
NEXT_PUBLIC_MOCK_API=false
